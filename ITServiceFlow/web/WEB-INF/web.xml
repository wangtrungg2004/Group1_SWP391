<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <!-- Servlet Declaration -->
    <servlet>
        <servlet-name>Login</servlet-name>
        <servlet-class>controller.Login</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Logout</servlet-name>
        <servlet-class>controller.Logout</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ForgotPassword</servlet-name>
        <servlet-class>controller.ForgotPassword</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ResetPassword</servlet-name>
        <servlet-class>controller.ResetPassword</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UserCreate</servlet-name>
        <servlet-class>controller.UserCreate</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>GoogleLogin</servlet-name>
        <servlet-class>controller.GoogleLogin</servlet-class>
    </servlet>
    <!-- Servlet Mapping -->
    <servlet>
        <servlet-name>ProblemUpdate</servlet-name>
        <servlet-class>controller.Problems.ProblemUpdate</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProblemAdd</servlet-name>
        <servlet-class>controller.Problems.ProblemAdd</servlet-class>
    </servlet>
<servlet>
    <servlet-name>MyTickets</servlet-name>
    <servlet-class>controller.ticket.user.MyTicketsController</servlet-class>
</servlet>
<servlet>
    <servlet-name>CreateTicket</servlet-name>
    <servlet-class>controller.ticket.user.TicketCreateController</servlet-class>
</servlet>
<servlet>
    <servlet-name>TicketDetailUser</servlet-name>
    <servlet-class>controller.ticket.user.TicketDetailUserController</servlet-class>
</servlet>
    <servlet-mapping>
        <servlet-name>Login</servlet-name>
        <url-pattern>/Login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/Logout</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ForgotPassword</servlet-name>
        <url-pattern>/ForgotPassword</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ResetPassword</servlet-name>
        <url-pattern>/ResetPassword</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UserCreate</servlet-name>
        <url-pattern>/UserCreate</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>GoogleLogin</servlet-name>
        <url-pattern>/GoogleLogin</url-pattern>
    </servlet-mapping>
    <!-- Filter Declaration -->
    <filter>
        <filter-name>AuthorizationFilter</filter-name>
        <filter-class>filter.AuthorizationFilter</filter-class>
    </filter>
    <!-- Filter Mapping -->
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/AdminDashboard.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/UserDashboard.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ITDashboard.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ManagerDashboard.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ProblemList</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ProblemAdd</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ProblemUpdate</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ProblemDetail</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ITProblemListController</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ProblemList.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ProblemAdd.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ProblemUpdate.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ProblemDetail.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ITSupportProblemList.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/UserCreate</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/UserCreate.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/user/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/it/*</url-pattern>
    </filter-mapping>
    <!-- Welcome File List -->
    <welcome-file-list>
        <welcome-file>Login</welcome-file>
        <welcome-file>Login.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
    <!-- Session Configuration (Optional) -->
    <servlet-mapping>
        <servlet-name>ProblemUpdate</servlet-name>
        <url-pattern>/ProblemUpdate</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProblemAdd</servlet-name>
        <url-pattern>/ProblemAdd</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
    <servlet-name>MyTickets</servlet-name>
    <url-pattern>/Tickets</url-pattern>
</servlet-mapping>
<servlet-mapping>
    <servlet-name>CreateTicket</servlet-name>
    <url-pattern>/CreateTicket</url-pattern>
</servlet-mapping>
<servlet-mapping>
    <servlet-name>TicketDetailUser</servlet-name>
    <url-pattern>/TicketDetailUser</url-pattern>
</servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
