@startuml
skinparam shadowing false
title Sequence Diagram - Password Hashing (SHA-256)
autonumber

participant "Admin/User" as Admin_User_0
participant "CreateOrResetServlet" as CreateOrResetServlet_1
participant "UserService" as UserService_2
participant "PasswordUtil" as PasswordUtil_3
participant "UserDao" as UserDao_4
participant "Database" as Database_5

Admin_User_0 -> CreateOrResetServlet_1 : submit raw password
CreateOrResetServlet_1 -> UserService_2 : create/reset operation
UserService_2 -> PasswordUtil_3 : sha256(rawPassword)
PasswordUtil_3 -> UserService_2 : password hash (hex)
UserService_2 -> UserDao_4 : insert/update with hash
UserDao_4 -> Database_5 : write Users.PasswordHash
UserDao_4 -> UserService_2 : operation result
UserService_2 -> CreateOrResetServlet_1 : success or failure
CreateOrResetServlet_1 -> Admin_User_0 : show message
@enduml
