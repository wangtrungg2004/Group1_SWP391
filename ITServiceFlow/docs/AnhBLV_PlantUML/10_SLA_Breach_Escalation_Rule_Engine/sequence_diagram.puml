@startuml
skinparam shadowing false
title Sequence Diagram - SLA Breach Escalation Rule Engine
autonumber

participant "IncomingRequest" as IncomingRequest_0
participant "SLAEscalationFilter" as SLAEscalationFilter_1
participant "SLATrackingService" as SLATrackingService_2
participant "SLATrackingDao" as SLATrackingDao_3
participant "NotificationDao" as NotificationDao_4
participant "SLAEscalationHistory" as SLAEscalationHistory_5

IncomingRequest_0 -> SLAEscalationFilter_1 : doFilter()
SLAEscalationFilter_1 -> SLATrackingService_2 : runEscalationSweep() if due
SLATrackingService_2 -> SLATrackingDao_3 : markBreachedTickets()
SLATrackingService_2 -> SLATrackingDao_3 : isEscalationHistoryEnabled()
SLATrackingService_2 -> SLATrackingDao_3 : getEscalationCandidates()
SLATrackingDao_3 -> SLATrackingService_2 : candidate list
SLATrackingService_2 -> SLATrackingDao_3 : hasEscalationHistory(ticket, stage, deadline)
SLATrackingService_2 -> NotificationDao_4 : send user or broadcast notification
SLATrackingService_2 -> SLATrackingDao_3 : addEscalationHistory(...)
SLATrackingDao_3 -> SLAEscalationHistory_5 : INSERT escalation event
SLAEscalationFilter_1 -> IncomingRequest_0 : continue chain.doFilter()
@enduml
