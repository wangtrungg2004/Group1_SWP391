@startuml
skinparam shadowing false
title Sequence Diagram - Create User Account
autonumber

participant "Admin" as Admin_0
participant "UserCreate.jsp" as UserCreate_jsp_1
participant "UserCreateServlet" as UserCreateServlet_2
participant "UserDao" as UserDao_3
participant "UserService" as UserService_4
participant "PasswordUtil" as PasswordUtil_5
participant "Database" as Database_6

Admin_0 -> UserCreate_jsp_1 : open create user page
UserCreate_jsp_1 -> UserCreateServlet_2 : GET /usermanagement/UserCreate
UserCreateServlet_2 -> UserDao_3 : getDepartmentOptions()
UserCreateServlet_2 -> UserDao_3 : getLocationOptions()
UserCreateServlet_2 -> UserCreate_jsp_1 : render form with dropdown data
Admin_0 -> UserCreate_jsp_1 : submit user form
UserCreate_jsp_1 -> UserCreateServlet_2 : POST /usermanagement/UserCreate
UserCreateServlet_2 -> UserService_4 : createUser(...)
UserService_4 -> PasswordUtil_5 : sha256(password)
UserService_4 -> UserDao_3 : createUser(...,passwordHash,...)
UserDao_3 -> Database_6 : INSERT Users
UserCreateServlet_2 -> Admin_0 : show success/error message
@enduml
