<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <!-- Servlet Declaration -->
    <servlet>
        <servlet-name>Login</servlet-name>
        <servlet-class>controller.Login</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Logout</servlet-name>
        <servlet-class>controller.Logout</servlet-class>
    </servlet>
    <!-- Servlet Mapping -->
    <servlet>
        <servlet-name>ProblemUpdate</servlet-name>
        <servlet-class>controller.Problems.ProblemUpdate</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProblemAdd</servlet-name>
        <servlet-class>controller.Problems.ProblemAdd</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>MyTickets</servlet-name>
        <servlet-class>controller.ticket.user.MyTicketsController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CreateTicket</servlet-name>
        <servlet-class>controller.ticket.user.TicketCreateController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TicketDetailUser</servlet-name>
        <servlet-class>controller.ticket.user.TicketDetailUserController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UserDashboard</servlet-name>
        <servlet-class>controller.ticket.user.UserDashboardController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AgentQueue</servlet-name>
        <servlet-class>controller.ticket.agent.AgentQueueController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AgentTicketDetail</servlet-name>
        <servlet-class>controller.ticket.agent.AgentTicketDetailController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AssignTicket</servlet-name>
        <servlet-class>controller.ticket.agent.AssignTicketController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UpdateTicketStatus</servlet-name>
        <servlet-class>controller.ticket.agent.UpdateStatusController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ProcessApproval</servlet-name>
        <servlet-class>controller.ticket.agent.ProcessApprovalController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CsatSurvey</servlet-name>
        <servlet-class>controller.ticket.user.CsatSurveyController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TicketTimeLog</servlet-name>
        <servlet-class>controller.ticket.agent.TicketTimeLogController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TicketTimeLog</servlet-name>
        <url-pattern>/TicketTimeLog</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Login</servlet-name>
        <url-pattern>/Login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/Logout</url-pattern>
    </servlet-mapping>
    <!-- Filter Declaration -->
    <filter>
        <filter-name>AuthorizationFilter</filter-name>
        <filter-class>filter.AuthorizationFilter</filter-class>
    </filter>
    <!-- Filter Mapping -->
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/AdminDashboard.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/UserDashboard.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/ITDashboard.jsp</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/user/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthorizationFilter</filter-name>
        <url-pattern>/it/*</url-pattern>
    </filter-mapping>
    <!-- Welcome File List -->
    <welcome-file-list>
        <welcome-file>Login</welcome-file>
        <welcome-file>Login.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>
    <!-- Session Configuration (Optional) -->
    <servlet-mapping>
        <servlet-name>ProblemUpdate</servlet-name>
        <url-pattern>/ProblemUpdate</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProblemAdd</servlet-name>
        <url-pattern>/ProblemAdd</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>MyTickets</servlet-name>
        <url-pattern>/Tickets</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CreateTicket</servlet-name>
        <url-pattern>/CreateTicket</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TicketDetailUser</servlet-name>
        <url-pattern>/TicketDetailUser</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UserDashboard</servlet-name>
        <url-pattern>/UserDashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AgentQueue</servlet-name>
        <url-pattern>/Queues</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AgentTicketDetail</servlet-name>
        <url-pattern>/TicketAgentDetail</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AssignTicket</servlet-name>
        <url-pattern>/AssignTicket</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>UpdateTicketStatus</servlet-name>
        <url-pattern>/UpdateStatus</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ProcessApproval</servlet-name>
        <url-pattern>/ProcessApproval</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
    <servlet-mapping>
        <servlet-name>CsatSurvey</servlet-name>
        <url-pattern>/CsatSurvey</url-pattern>
    </servlet-mapping>
</web-app>
