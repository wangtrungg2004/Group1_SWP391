@startuml
skinparam shadowing false
title Sequence Diagram - Temporary Permission Assignment
autonumber

participant "Requester" as Requester_0
participant "TemporaryAccessRequest.jsp" as TemporaryAccessRequest_jsp_1
participant "RequestController" as RequestController_2
participant "TemporaryRoleAccessService" as TemporaryRoleAccessService_3
participant "TemporaryRoleRequestDao" as TemporaryRoleRequestDao_4
participant "Approver" as Approver_5
participant "ApprovalController" as ApprovalController_6

Requester_0 -> TemporaryAccessRequest_jsp_1 : fill role request form
TemporaryAccessRequest_jsp_1 -> RequestController_2 : POST action=create
RequestController_2 -> TemporaryRoleAccessService_3 : submitRequest(...)
TemporaryRoleAccessService_3 -> TemporaryRoleRequestDao_4 : hasPending + createRequest
RequestController_2 -> Requester_0 : redirect with flash result
Approver_5 -> ApprovalController_6 : GET /TemporaryAccessApproval
ApprovalController_6 -> TemporaryRoleAccessService_3 : getPendingRequests()
TemporaryRoleAccessService_3 -> TemporaryRoleRequestDao_4 : getPendingRequests()
Approver_5 -> ApprovalController_6 : POST approve/reject/revoke
ApprovalController_6 -> TemporaryRoleAccessService_3 : processDecision(...)
TemporaryRoleAccessService_3 -> TemporaryRoleRequestDao_4 : approve/reject/revoke
ApprovalController_6 -> Approver_5 : redirect with decision message
@enduml
